.popup-header {
  display: flex;
  align-items: center;
  height: 116rpx;
}

.popup-title {
  flex: 1;
  text-align: center;
  font-weight: 600;
  font-size: 36rpx;
  color: var(--td-text-color-primary);
}

.popup-body {
  margin: var(--td-spacer-3) 0;
  display: flex;
  flex-direction: column;
  gap: var(--td-spacer-2);
}

.save-buttons {
  margin: 0 var(--td-spacer-2);
  bottom: 0;
  display: flex;
  gap: var(--td-spacer-2);
}

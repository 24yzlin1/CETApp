.progress-slider {
  margin: var(--td-spacer-2) 0;
}

.word-card {
  display: flex;
  flex-direction: column;
}

.word-card-english {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--td-spacer);
  padding: var(--td-spacer-4) 0;
}

.english-word {
  font-size: var(--td-font-size-xxl);
  font-weight: bold;
}

.english-pronunciation {
  font-size: var(--td-font-size-l);
  color: var(--td-text-color-disabled);
}

.english-pos {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--td-radius-circle);
  background-color: var(--td-primary-color-1);

  font-weight: bold;
  font-size: var(--td-font-size-s);
  color: var(--td-primary-color-7);
}

.clock-in-success {
  width: 100vw;
  height: 100vw;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--td-spacer-4);
}

.fab {
  display: flex;
  gap: var(--td-spacer);
}

.popup-header {
  display: flex;
  align-items: center;
  height: 116rpx;
}

.popup-title {
  flex: 1;
  text-align: center;
  font-weight: 600;
  font-size: 36rpx;
  color: var(--td-text-color-primary);
}

.capsule {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.capsule-icon {
  flex: 1;
  position: relative;
}

.capsule-icon:last-child::before {
  content: "";
  display: block;
  position: absolute;
  left: -1px;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 18px;
  background: #e7e7e7;
}

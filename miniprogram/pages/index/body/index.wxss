.clock-in-card {
  height: 75vw;
  margin: var(--td-spacer-2);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: var(--td-spacer-2);
}

.welcome-message {
  font-size: var(--td-font-size-xxl);
  font-weight: bold;
}

.clock-in-text {
  font-size: var(--td-font-size-l);
  font-weight: bolder;
}

.count-down {
  display: flex;
  flex-direction: column;
  gap: var(--td-spacer);
  font-weight: bold;
}

.clock-in-buttons {
  bottom: 0;
  display: flex;
  gap: var(--td-spacer-2);
}

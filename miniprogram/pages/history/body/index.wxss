.history-card {
  margin: var(--td-spacer-2) 0;
}

.date {
  margin: var(--td-spacer) 0;
  font-size: var(--td-font-size-xl);
  font-weight: bold;
}
page {
  background-image:
    linear-gradient(
      rgba(19,42,76,.72),
      rgba(19,42,76,.72)
    ),
    url('/assets/images/bg-growth.jpg');

  background-size: cover;
}

.page-body {
  padding: 20rpx;
}

.growth-banner {

  padding: 40rpx;

  border-radius: 30rpx;

  background: rgba(255,255,255,.16);

  backdrop-filter: blur(18px);

  margin-bottom: 24rpx;
}

.growth-title {

  color: white;

  font-size: 44rpx;

  font-weight: bold;
}

.growth-sub {

  color: rgba(255,255,255,.9);

  margin-top: 12rpx;
}

.dashboard {

  display: flex;

  gap: 16rpx;

  margin-bottom: 24rpx;
}

.dashboard-card {

  flex: 1;

  text-align: center;

  color: white;

  padding: 24rpx;

  border-radius: 24rpx;

  background: rgba(255,255,255,.14);

  backdrop-filter: blur(16px);
}
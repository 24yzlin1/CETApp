.bg{
  width: 100%;
  height: 100vh;
  position: fixed;
  top: 0;
  left: 0;
  z-index: -1;
}

.bg image{
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.history-card {
  margin: 24rpx 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.history-cell-group {
  margin: 0;
}

.date {
  margin: var(--td-spacer) 0;
  font-size: var(--td-font-size-xl);
  font-weight: bold;
}

.growth-title {
  color: rgba(1, 6, 22, 0.9);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 40rpx;
}

.growth-sub {
  color: rgba(1, 6, 22, 0.9);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 40rpx;
}
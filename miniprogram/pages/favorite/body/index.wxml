<t-message id="t-message" />

<t-popup
bind:visible-change="popupHideHandle"
placement="bottom"
style="height: 75vw;"
visible="{{isShowPopup}}"

>

  <view class="popup-header">
    <view class="popup-title">保存词汇表</view>
  </view>

  <view class="popup-body">
    <t-input
      bindchange="saveNameChangeHandle"
      borderless="{{true}}"
      label="名称"
      value="{{saveName}}"
    />

```
<view class="save-buttons">
  <t-button bindtap="popupHideHandle">
    取消
  </t-button>

  <t-button
    bindtap="saveHandle"
    theme="primary"
  >
    保存
  </t-button>
</view>

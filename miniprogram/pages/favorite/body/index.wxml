<view class="page">
  <t-navbar
    left-arrow="{{true}}"
    title="宝藏单词库"
  />

  <view class="page-body">

```
<view class="favorite-title">
  宝藏单词库
</view>

<view class="favorite-sub">
  收藏值得反复记忆的单词
</view>

<view class="favorite-stats">
  <view class="bg">
    <image
      src="{{favoriteDisplay.length === 0 ? '/pages/images/bg.png' : '/pages/images/bg1.png'}}"
      mode="aspectFill"
    />
  </view>
</view>

<t-tabs
  bindchange="tabChangeHandle"
  value="{{tabIndex}}"
>
  <t-tab-panel
    wx:for="{{tabOptions}}"
    wx:key="option"
    label="{{item}}"
    value="{{index}}"
  />
</t-tabs>

<!-- 收藏单词列表 -->
<view
  class="favorite-card"
  wx:for="{{favoriteDisplay}}"
  wx:key="favorite"
>
  <t-cell
    bordered="{{false}}"
    catchtap="itemTapHandle"
    data-index="{{index}}"
    title="{{cardsDisplay[index][1][0]}}"
    description="{{item[1][0]+'  '+wordListTitle[item[1][1]]}}"
    hover="{{true}}"
  >
    <t-button
      slot="right-icon"
      catchtap="itemDeleteHandle"
      data-index="{{item[0]}}"
      icon="close"
      shape="circle"
      theme="danger"
      variant="text"
    />
  </t-cell>
</view>

<t-fab wx:if="{{favoriteDisplay.length!==0}}">
  <view class="fab">
    <t-button
      bindtap="popupShowHandle"
      icon="save"
      shape="circle"
      size="large"
      theme="primary"
    />
  </view>
</t-fab>
```

  </view>
</view>

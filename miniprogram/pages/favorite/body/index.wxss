.bg{
  width: 100%;
  height: 100vh;
  position: fixed;
  top: 0;
  left: 0;
  z-index: -1;
}

.bg image{
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.popup-header {
  display: flex;
  align-items: center;
  height: 116rpx;
}

.popup-title {
  flex: 1;
  text-align: center;
  font-weight: 600;
  font-size: 36rpx;
  color: var(--td-text-color-primary);
}

.popup-body {
  margin: 24rpx 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
.page-body{
  padding: 0 16rpx;
  box-sizing: border-box;
}


.save-buttons {
  margin: 0 var(--td-spacer-2);
  bottom: 0;
  display: flex;
  gap: var(--td-spacer-2);
}



.favorite-title {

  color: rgba(0, 0, 0, 0.9);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 20rpx;
}
.favorite-sub {

  color: rgba(0, 0, 0, 0.9);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 20rpx;
}
.growth-sub { 

  color: rgba(0, 0, 0, 0.9);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 40rpx;
}

.favorite-stats {

  display: flex;

  gap: 16rpx;

  margin-bottom: 24rpx;
}

.gold-card {

  flex: 1;

  text-align: center;

  color: white;

  padding: 24rpx;

  border-radius: 24rpx;

  background: rgba(24, 8, 205, 0.745);

  backdrop-filter: blur(15px);
}
.favorite-card{
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;

  background: rgba(255,255,255,.88);
  backdrop-filter: blur(15px);

  box-shadow:
    0 8rpx 24rpx rgba(0,0,0,.06);
}
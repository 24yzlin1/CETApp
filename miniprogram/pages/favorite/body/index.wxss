.popup-header {
  display: flex;
  align-items: center;
  height: 116rpx;
}

.popup-title {
  flex: 1;
  text-align: center;
  font-weight: 600;
  font-size: 36rpx;
  color: var(--td-text-color-primary);
}

.popup-body {
  margin: var(--td-spacer-3) 0;
  display: flex;
  flex-direction: column;
  gap: var(--td-spacer-2);
}

.save-buttons {
  margin: 0 var(--td-spacer-2);
  bottom: 0;
  display: flex;
  gap: var(--td-spacer-2);
}
page {

  background-image:
    linear-gradient(
      rgba(85,57,0,.45),
      rgba(85,57,0,.45)
    ),
    url('/assets/images/bg-library.jpg');

  background-size: cover;
}

.page-body {
  padding: 20rpx;
}

.favorite-banner {

  padding: 40rpx;

  border-radius: 32rpx;

  background: rgba(255,255,255,.15);

  backdrop-filter: blur(18px);

  margin-bottom: 24rpx;
}

.favorite-title {

  color: white;

  font-size: 44rpx;

  font-weight: bold;
}

.favorite-sub {

  color: rgba(255,255,255,.92);

  margin-top: 12rpx;
}

.favorite-stats {

  display: flex;

  gap: 16rpx;

  margin-bottom: 24rpx;
}

.gold-card {

  flex: 1;

  text-align: center;

  color: white;

  padding: 24rpx;

  border-radius: 24rpx;

  background: rgba(255,255,255,.12);

  backdrop-filter: blur(15px);
}
.popup-header {
  display: flex;
  align-items: center;
  height: 116rpx;
}

.popup-title {
  flex: 1;
  text-align: center;
  font-weight: 600;
  font-size: 36rpx;
  color: var(--td-text-color-primary);
}

.progress-slider {
  margin: var(--td-spacer-2) 0;
}

.game-card {
  display: flex;
  flex-direction: column;
}

.game-card-english {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--td-spacer-2);
  padding: var(--td-spacer-4) 0;
}

.english-word {
  font-size: var(--td-font-size-xxl);
  font-weight: bold;
}

.english-pronunciation {
  font-size: var(--td-font-size-l);
  color: var(--td-text-color-disabled);
}

.game-start {
  width: 100vw;
  height: 100vw;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--td-spacer-4);
}

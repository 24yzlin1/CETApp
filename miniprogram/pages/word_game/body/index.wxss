.bg{
  width: 100%;
  height: 100vh;
  position: fixed;
  top: 0;
  left: 0;
  z-index: -1;
}

.bg image{
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.game-tips {
  position: fixed;
  top: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 999;
  margin: 0;
  padding: 16rpx 32rpx;
  width: 80%;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.game-tips.success {
  background-color: rgba(72, 187, 120, 0.9);
  color: white;
}

.game-tips.error {
  background-color: rgba(245, 108, 108, 0.9);
  color: white;
}

.correct-cell {
  background-color: rgba(72, 187, 120, 0.5) !important;
  color: white;
}

.wrong-cell {
  background-color: rgba(245, 108, 108, 0.5) !important;
  color: white;
}

.custom-cell {
  background-color: rgba(255, 255, 255, 0.5) !important;
}

.popup-header {
  display: flex;
  align-items: center;
  height: 116rpx;
}

.popup-title {
  flex: 1;
  text-align: center;
  font-weight: 600;
  font-size: 36rpx;
  color: var(--td-text-color-primary);
}

.progress-slider {
  margin: var(--td-spacer-2) 0;
}

.game-card {
  display: flex;
  flex-direction: column;
}

.game-card-english {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--td-spacer-2);
  padding: var(--td-spacer-4) 0;
}

.english-word {
  font-size: var(--td-font-size-xxl);
  font-weight: bold;
  background-color: #FF000000;
}

.english-pronunciation {
  font-size: var(--td-font-size-l);
  color: var(--td-text-color-disabled);
  background-color: #FF000000;
}

.game-start {
  width: 100vw;
  height: 100vw;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--td-spacer-4);
}

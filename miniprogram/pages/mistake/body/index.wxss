.bg{
  width: 100%;
  height: 100vh;
  position: fixed;
  top: 0;
  left: 0;
  z-index: -1;
}

.bg image{
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.page-header{
  width: 100%;
  margin-top: 0;
  text-align: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.page-title{
  font-size: 36rpx;
  font-weight: 700;
  color: #000;
  line-height: 48rpx;
}
.mistake-card {
  margin: var(--td-spacer-2) 0;
}

.word {
  margin: var(--td-spacer) 0;
  font-size: var(--td-font-size-xl);
  font-weight: bold;
}

.page-body {
  padding: 0 10rpx;
  box-sizing: border-box;
}

/* 关键：左右padding和stat-card保持一样 16rpx */
.mistake-banner {
  border-radius: 32rpx;
  padding: 23rpx 16rpx;
  margin-bottom: 24rpx;
  background: rgba(212, 201, 215, 0.332);
  backdrop-filter: blur(18px);
  box-sizing: border-box;
}

.banner-title {
  color: rgba(1, 6, 22, 0.9);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 22rpx;
}

.banner-subtitle {
  color: rgba(1, 6, 22, 0.9);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 22rpx;
}

.banner-count {
  color: rgb(10, 1, 1);
  font-size: 44rpx;
  font-weight: bold;
  margin-left: 22rpx;
}

.mistake-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.stat-card {
  flex: 1;
  text-align: center;
  /* 和banner左右内边距统一16rpx */
  padding: 24rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,.14);
  backdrop-filter: blur(15px);
  box-sizing: border-box;
}
 
.stat-icon {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.stat-text {
  color: white;
  margin-top: 10rpx;
}
<view class="page">
  <t-navbar left-arrow="{{true}}" />
  <view class="page-body">
  <view class="mistake-banner">
  <view class="banner-content">
    <view class="banner-title">📚 错题本</view>
    <view class="banner-subtitle">
      查漏补缺 · 巩固提升
    </view>

    <view class="banner-count">
      {{mistake.length}} 条待复习
    </view>
  </view>
</view>

<view class="mistake-stats">
  <view class="stat-card">
    <view class="stat-icon">🔥</view>
    <view class="stat-text">今日复习</view>
  </view>

  <view class="stat-card">
    <view class="stat-icon">🎯</view>
    <view class="stat-text">正确率</view>
  </view>

  <view class="stat-card">
    <view class="stat-icon">📖</view>
    <view class="stat-text">错题数</view>
  </view>
</view>
    <view
      class="mistake-card"
      wx:for="{{mistake}}"
      wx:for-index="cardIndex"
      wx:for-item="cardItem"
      wx:key="mistake"
    >
      <t-cell-group theme="card">
        <t-cell description="{{cardItem[1][0]}}">
          <view
            class="word"
            slot="title"
          >{{cardItem[0][1][1][0]}}</view>
        </t-cell>
        <t-cell
          bordered="{{false}}"
          catchtap="itemTapHandle"
          data-target="{{cardIndex}}"
          hover
          left-icon="{{index===cardItem[0][2]?'check-circle':'circle'}}"
          title="{{item}}"
          wx:for="{{cardItem[0][3]}}"
          wx:key="option"
        ></t-cell>
      </t-cell-group>
    </view>
    <t-fab wx:if="{{mistake.length!==0}}">
      <view class="fab">
        <t-button
          bindtap="clearHandle"
          icon="clear"
          shape="circle"
          size="large"
          theme="primary"
        ></t-button>
      </view>
    </t-fab>
  </view>
</view>

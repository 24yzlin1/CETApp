/* =============================================
   可爱淡色聊天气泡样式 (全局穿透)
   ============================================= */

/* --- 用户气泡 - 淡粉可爱风 + 波点 + 小尾巴 --- */
.t-chat-message.user .t-chat-content {
  background-color: #fce4ec !important;
  background-image:
    radial-gradient(
      circle at 30% 40%,
      rgba(248, 187, 208, 0.3) 0,
      rgba(248, 187, 208, 0.3) 4rpx,
      transparent 4rpx
    ),
    radial-gradient(
      circle at 70% 60%,
      rgba(248, 187, 208, 0.25) 0,
      rgba(248, 187, 208, 0.25) 3rpx,
      transparent 3rpx
    ),
    radial-gradient(
      circle at 50% 80%,
      rgba(248, 187, 208, 0.2) 0,
      rgba(248, 187, 208, 0.2) 5rpx,
      transparent 5rpx
    ),
    radial-gradient(
      circle at 20% 10%,
      rgba(248, 187, 208, 0.2) 0,
      rgba(248, 187, 208, 0.2) 3rpx,
      transparent 3rpx
    ),
    radial-gradient(
      circle at 85% 20%,
      rgba(248, 187, 208, 0.25) 0,
      rgba(248, 187, 208, 0.25) 4rpx,
      transparent 4rpx
    ),
    linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%) !important;
  padding: 20rpx 28rpx !important;
  border-radius: 24rpx 24rpx 8rpx 24rpx !important;
  box-shadow: 0 4rpx 16rpx rgba(244, 143, 177, 0.2) !important;
  border: none !important;
  max-width: 75vw !important;
  width: fit-content !important;
  margin-left: auto !important;
  position: relative !important;
}

/* 小尾巴 */
.t-chat-message.user .t-chat-content::after {
  content: "" !important;
  position: absolute !important;
  bottom: 0 !important;
  right: -12rpx !important;
  width: 24rpx !important;
  height: 24rpx !important;
  background: radial-gradient(
    circle at 0 0,
    #f8bbd0 0%,
    #f8bbd0 55%,
    transparent 56%
  ) !important;
}

/* 小星星装饰 */
.t-chat-message.user .t-chat-content::before {
  content: "✦" !important;
  position: absolute !important;
  top: -8rpx !important;
  right: -8rpx !important;
  font-size: 20rpx !important;
  color: rgba(244, 143, 177, 0.5) !important;
  line-height: 1 !important;
}

.t-chat-message.user .t-chat-content .t-chat-content__user {
  color: #6d3349 !important;
  font-size: 28rpx !important;
  line-height: 1.7 !important;
  font-weight: 500 !important;
  position: relative !important;
  z-index: 1 !important;
}

/* --- AI 气泡 - 淡紫可爱风 + 波点 + 小尾巴 --- */
.t-chat-message.assistant .t-chat-content {
  background-color: #f3e5f5 !important;
  background-image:
    radial-gradient(
      circle at 25% 35%,
      rgba(206, 147, 216, 0.25) 0,
      rgba(206, 147, 216, 0.25) 4rpx,
      transparent 4rpx
    ),
    radial-gradient(
      circle at 65% 70%,
      rgba(206, 147, 216, 0.2) 0,
      rgba(206, 147, 216, 0.2) 3rpx,
      transparent 3rpx
    ),
    radial-gradient(
      circle at 45% 15%,
      rgba(206, 147, 216, 0.2) 0,
      rgba(206, 147, 216, 0.2) 5rpx,
      transparent 5rpx
    ),
    radial-gradient(
      circle at 80% 40%,
      rgba(206, 147, 216, 0.25) 0,
      rgba(206, 147, 216, 0.25) 3rpx,
      transparent 3rpx
    ),
    radial-gradient(
      circle at 15% 75%,
      rgba(206, 147, 216, 0.2) 0,
      rgba(206, 147, 216, 0.2) 4rpx,
      transparent 4rpx
    ),
    linear-gradient(135deg, #f3e5f5 0%, #ede7f6 100%) !important;
  padding: 22rpx 28rpx !important;
  border-radius: 24rpx 24rpx 24rpx 8rpx !important;
  box-shadow: 0 3rpx 14rpx rgba(206, 147, 216, 0.15) !important;
  border: none !important;
  max-width: 82vw !important;
  width: fit-content !important;
  margin-right: auto !important;
  position: relative !important;
}

/* 小尾巴 */
.t-chat-message.assistant .t-chat-content::after {
  content: "" !important;
  position: absolute !important;
  bottom: 0 !important;
  left: -12rpx !important;
  width: 24rpx !important;
  height: 24rpx !important;
  background: radial-gradient(
    circle at 100% 0,
    #ede7f6 0%,
    #ede7f6 55%,
    transparent 56%
  ) !important;
}

/* 小星星装饰 */
.t-chat-message.assistant .t-chat-content::before {
  content: "✧" !important;
  position: absolute !important;
  top: -8rpx !important;
  left: -8rpx !important;
  font-size: 20rpx !important;
  color: rgba(206, 147, 216, 0.5) !important;
  line-height: 1 !important;
}

.t-chat-message.assistant .t-chat-content .t-chat-content__assistant {
  color: #4a2c5a !important;
  font-size: 28rpx !important;
  line-height: 1.8 !important;
  position: relative !important;
  z-index: 1 !important;
}

/* --- 加载中气泡 --- */
.t-chat-message.assistant .t-chat-loading {
  background: linear-gradient(135deg, #f3e5f5 0%, #ede7f6 100%) !important;
  border-radius: 24rpx 24rpx 24rpx 8rpx !important;
  padding: 22rpx 28rpx !important;
  border: none !important;
  box-shadow: 0 3rpx 14rpx rgba(206, 147, 216, 0.12) !important;
  width: fit-content !important;
  max-width: 82vw !important;
}

/* 隐藏消息头像 */
.t-chat-message.user .t-chat-message__avatar,
.t-chat-message.assistant .t-chat-message__avatar {
  display: none !important;
}

/* --- Markdown 内容美化 --- */
.t-chat-markdown {
  line-height: 1.8 !important;
}

.t-chat-markdown-p {
  margin: 6rpx 0 !important;
}

.t-chat-markdown-h1,
.t-chat-markdown-h2,
.t-chat-markdown-h3,
.t-chat-markdown-h4 {
  margin: 16rpx 0 8rpx !important;
  color: #4a2c5a !important;
}

.t-chat-markdown-h1 {
  font-size: 1.5em !important;
}
.t-chat-markdown-h2 {
  font-size: 1.3em !important;
}
.t-chat-markdown-h3 {
  font-size: 1.15em !important;
}

.t-chat-markdown-codespan {
  background: rgba(206, 147, 216, 0.12) !important;
  border-color: rgba(206, 147, 216, 0.2) !important;
  color: #7b1fa2 !important;
  border-radius: 6rpx !important;
  font-size: 26rpx !important;
}

.t-chat-markdown-blockquote {
  border-left: 4rpx solid #ce93d8 !important;
  background: rgba(206, 147, 216, 0.06) !important;
  border-radius: 0 8rpx 8rpx 0 !important;
  padding: 12rpx 20rpx !important;
  margin: 12rpx 0 !important;
}

.t-chat-markdown-pre {
  background: rgba(206, 147, 216, 0.06) !important;
  border-radius: 12rpx !important;
  padding: 20rpx !important;
  overflow-x: auto !important;
  border: 1rpx solid rgba(206, 147, 216, 0.12) !important;
}

.t-chat-markdown-code {
  font-size: 24rpx !important;
  line-height: 1.6 !important;
}
